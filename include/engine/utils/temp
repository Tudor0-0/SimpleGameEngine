        function scaleRectangle(rectX, rectY, rectW, rectH, pivotX, pivotY, scale) {
            const newWidth = rectW * scale;
            const newHeight = rectH * scale;

            const newX = pivotX + (rectX - pivotX) * scale;
            const newY = pivotY + (rectY - pivotY) * scale;

            return {
                x: newX,
                y: newY,
                width: newWidth,
                height: newHeight
            };
        }